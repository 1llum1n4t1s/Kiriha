<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kiriha.Views.ThemedDialogWindow"
        Background="Transparent">
    <Panel>
        <ExperimentalAcrylicBorder x:Name="AcrylicBackdrop" IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                             MaterialOpacity="0.65"
                                             TintColor="{DynamicResource AcrylicTintColor}"
                                             TintOpacity="0.8" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- アクリル OFF 時だけ ContentBg を見せる。ON 時はコード側で透明化し、
             Lhamiel と同様にコンテンツをアクリル面へ直接重ねる。 -->
        <Border x:Name="ContentSurface" Background="{DynamicResource ContentBg}">
            <ContentPresenter x:Name="DialogContentPresenter" />
        </Border>
    </Panel>
</Window>
