<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiriha.ViewModels"
        xmlns:m="using:Kiriha.Models"
        xmlns:c="using:Kiriha.Controls"
        x:Class="Kiriha.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="/icon/app_icon.png"
        Width="1100" Height="720"
        MinWidth="560" MinHeight="360"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="42"
        WindowDecorations="BorderOnly"
        Background="{DynamicResource TabStripBg}">

    <Window.Styles>
        <!-- Chrome 風タブ -->
        <Style Selector="ListBox.tabs">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="0,7,0,0" />
            <Setter Property="CornerRadius" Value="12,12,0,0" />
            <Setter Property="Background" Value="{DynamicResource TabIdleBg}" />
            <Setter Property="BorderThickness" Value="0" />
            <!-- Fluent既定テンプレートのフォーカスリング/選択インジケーターがタブの角丸と噛み合わず
                 二重の枠に見えるため、背景・枠線・角丸だけを描く最小テンプレートに置き換える。
                 PART名は既存の :pointerover / :selected セレクターと合わせている。 -->
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                       Background="{TemplateBinding Background}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BorderThickness="{TemplateBinding BorderThickness}"
                                       CornerRadius="{TemplateBinding CornerRadius}"
                                       Content="{TemplateBinding Content}"
                                       ContentTemplate="{TemplateBinding ContentTemplate}"
                                       Padding="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabHoverBg}" />
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabActiveBg}" />
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabActiveBg}" />
        </Style>
        <!-- ドラッグ中は掴んだタブがカーソルへ追従するゴースト（TabDragGhost）で表現するので、
             元の位置は「抜けた跡」として薄く沈める（placeholder）。 -->
        <Style Selector="ListBox.tabs ListBoxItem.dragging">
            <Setter Property="Opacity" Value="0.3" />
        </Style>
        <!-- ドロップ先の挿入位置を、対象タブの左辺のアクセントバーで示す。 -->
        <Style Selector="ListBox.tabs ListBoxItem.droptarget /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem.droptarget-after /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="0,0,3,0" />
        </Style>

        <!-- 垂直タブ。色は既存トークンだけを使い、選択状態は濃い面 + アクセント線で明確にする。 -->
        <Style Selector="ListBox.verticaltabs">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,2,8,8" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabHoverBg}" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabActiveBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabActiveBg}" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem.dragging">
            <Setter Property="Opacity" Value="0.3" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem.droptarget /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="0,3,0,0" />
        </Style>
        <Style Selector="ListBox.verticaltabs ListBoxItem.droptarget-after /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
        </Style>
        <Style Selector="Button.verticaltabaction">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.verticaltabaction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="Border.tabicon">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <!-- 固定タブのアイコンは専用の背景色を持たせない。タブ自体の背景（非選択 / ホバー / 選択中）が
             そのまま透けるので、内側に別の色の箱が入れ子になって見える「二重背景」を避けられる。
             固定タブであることはタイトル非表示・幅が縮む挙動自体で伝わる（Chrome と同じ）。 -->

        <!-- Fluent アイコン共通 -->
        <Style Selector="TextBlock.fico">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
        </Style>

        <!-- 丸いナビゲーションボタン（戻る/進む/更新/上へ） -->
        <Style Selector="Button.nav">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>
        <Style Selector="Button.nav:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.35" />
        </Style>

        <!-- タブの閉じるボタン -->
        <Style Selector="Button.tabclose">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tabclose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TabCloseHoverBg}" />
        </Style>

        <!-- ウィンドウキャプションボタン -->
        <Style Selector="Button.caption">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CaptionHoverBg}" />
        </Style>
        <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123" />
        </Style>
        <Style Selector="Button.caption.close:pointerover">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- コマンドバーのボタン（テキスト付き / アイコンのみ共通） -->
        <Style Selector="Button.cmd">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="Button.cmd:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>
        <Style Selector="Button.cmd:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <Style Selector="Button.cmdicon">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
        </Style>

        <!-- パンくずのセグメントボタン -->
        <Style Selector="Button.crumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.crumb:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CrumbHoverBg}" />
        </Style>

        <!-- 詳細表示のカラムヘッダー -->
        <Style Selector="Button.colhead">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.colhead:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>

        <!-- カラム幅変更用の Thumb -->
        <Style Selector="Thumb.colsplit">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWestEast" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent">
                        <Border Width="1" Background="{DynamicResource Divider}" HorizontalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- アドレスバーと検索ボックスの間は、リサイズ領域だけを残して区切り線を描かない -->
        <Style Selector="Thumb.searchsplit">
            <Setter Property="Width" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWestEast" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Border.detailcolumn.dragging">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Border.detailcolumn.droptarget">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>

        <!-- お気に入りバーのボタン -->
        <Style Selector="Button.bookmark">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.bookmark:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>

        <!-- 左ペイン（クイックアクセス / PC） -->
        <Style Selector="ListBox.sidebar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,4" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="6,1" />
        </Style>

        <!-- ファイル一覧（詳細 / 一覧）の行（高さは行テンプレート側で RowHeight にバインド） -->
        <Style Selector="ListBox.files ListBoxItem">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
        <Style Selector="ListBox.files.details ListBoxItem">
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="ListBox.files.list ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>

        <!-- ファイル一覧（アイコン表示）のセル -->
        <Style Selector="ListBox.icons ListBoxItem">
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="2" />
        </Style>

        <!-- ===== 設定タブ（Lhamiel / Shisui / RealTimeTranslator の実装を調査し数値を合わせた共通デザイン言語） =====
             左は浮遊カード状のサイドバー TabControl（180px, CornerRadius 14 + BoxShadow で浮かせる）、
             右は HeaderedContentControl ベースのガラスカードを積む構成。角丸 14 (カード) / 6 (ナビ選択項目)、
             見出し 20/13/12 の数値規則は3アプリとも同一だったためそのまま採用し、色のみ Kiriha 側のテーマトークンに差し替えている。 -->
        <Style Selector="TabControl.settingsnav">
            <Setter Property="TabStripPlacement" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="204,*">
                        <Border Grid.Column="0" Margin="0,0,18,0" Padding="10"
                                Background="{DynamicResource SettingsNavBg}"
                                BorderBrush="{DynamicResource SettingsCardBorder}" BorderThickness="1"
                                BoxShadow="0 14 34 0 #26000000, 0 3 10 0 #18000000, inset 0 1 0 0 #26FFFFFF"
                                CornerRadius="18">
                            <ItemsPresenter Name="PART_ItemsPresenter">
                                <ItemsPresenter.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsPresenter.ItemsPanel>
                            </ItemsPresenter>
                        </Border>
                        <ContentPresenter Name="PART_SelectedContentHost" Grid.Column="1"
                                          Margin="4,0,0,0"
                                          Content="{TemplateBinding SelectedContent}"
                                          ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabControl.settingsnav TabItem">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TabControl.settingsnav TabItem /template/ Border#PART_LayoutRoot">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TabControl.settingsnav TabItem /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="TabControl.settingsnav TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource HoverBg}" />
        </Style>
        <Style Selector="TabControl.settingsnav TabItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SettingsNavSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>

        <!-- 見出し・カード・補足文のスタイルクラス -->
        <Style Selector="TextBlock.settingsh1">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="Border.settingshero">
            <Setter Property="Background" Value="{DynamicResource SettingsHeroBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="BoxShadow" Value="0 8 22 0 #16000000, inset 0 1 0 0 #24FFFFFF" />
        </Style>
        <Style Selector="Border.settingsheroicon">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{DynamicResource SettingsIconBg}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>
        <Style Selector="TextBlock.settingsherosubtitle">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <!-- 見出し行を持たない単純パネル（ショートカット一覧・バージョン情報）用のガラスカード -->
        <Style Selector="Border.settingscard">
            <Setter Property="Background" Value="{DynamicResource SettingsCardBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="BoxShadow" Value="0 5 16 0 #12000000, inset 0 1 0 0 #20FFFFFF" />
        </Style>
        <!-- 小見出し付きガラスカード。3アプリとも HeaderedContentControl を使い回しているのに合わせて実コントロールをテンプレート化 -->
        <Style Selector="HeaderedContentControl.settingscard">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Margin="0,0,0,14" Padding="18"
                            Background="{DynamicResource SettingsCardBg}"
                            BorderBrush="{DynamicResource SettingsCardBorder}" BorderThickness="1" CornerRadius="16"
                            BoxShadow="0 5 16 0 #12000000, inset 0 1 0 0 #20FFFFFF">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,12" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Text="{TemplateBinding Header}" />
                            <ContentPresenter Name="PART_ContentPresenter" Content="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TextBlock.settingscaption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="28,-4,0,0" />
        </Style>
        <Style Selector="StackPanel.settingsfields > CheckBox">
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style Selector="TextBox.settingsfield, ComboBox.settingsfield">
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="TabControl.settingsnav Button.cmd">
            <Setter Property="Background" Value="{DynamicResource SettingsButtonBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Window.Styles>

    <Panel>
        <!-- Lhamiel / RealTimeTranslator と同等のアクリル背景（設定 > 表示 でON/OFF）。
             実際にぼかしが乗るには Window.Background 側（TabStripBg）が透明である必要があり、
             ON/OFF の色差し替えは ThemeService.ApplyAcrylicBackgrounds が担う。 -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" MaterialOpacity="0.85"
                                             TintColor="{DynamicResource AcrylicTintColor}" TintOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

    <Grid RowDefinitions="42,*" ColumnDefinitions="Auto,*">

        <!-- タブのドラッグ中に、掴んだタブがカーソルへ追従して浮くゴースト表示のオーバーレイ。
             ヒットテストは無効（下の操作を邪魔しない）で、全面に最前面で重ねる。 -->
        <Canvas x:Name="TabDragOverlay" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                IsHitTestVisible="False" ZIndex="1000">
            <Border x:Name="TabDragGhost" IsVisible="False"
                    Height="30" MinWidth="110" MaxWidth="240"
                    Background="{DynamicResource TabActiveBg}"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                    CornerRadius="8" Opacity="0.95"
                    BoxShadow="0 8 22 0 #66000000">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="8,0,12,0" Spacing="8">
                    <TextBlock x:Name="TabDragGhostIcon" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TabDragGhostText" FontSize="12.5" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Canvas>

        <!-- ===== タブストリップ（タイトルバー領域） ===== -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto"
              Background="Transparent"
              PointerPressed="TitleBar_PointerPressed"
              DoubleTapped="TitleBar_DoubleTapped">

            <!-- Edge と同じ位置に、横タブから垂直タブへ切り替える入口を置く。 -->
            <Button x:Name="VerticalTabModeButton" Grid.Column="0" Classes="nav" Width="30" Height="30"
                    Margin="8,6,2,0" Content="☰" FontFamily="Segoe UI Symbol"
                    AutomationProperties.Name="垂直タブに切り替える"
                    IsVisible="{Binding UseHorizontalTabs}"
                    Command="{Binding ToggleVerticalTabsCommand}"
                    ToolTip.Tip="垂直タブに切り替える" />

            <!-- 垂直表示ではタブ列を左へ移し、タイトルバーは現在の場所を簡潔に示す。 -->
            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                        Margin="14,0,0,0" Spacing="10" VerticalAlignment="Center"
                        IsHitTestVisible="False" IsVisible="{Binding UseVerticalTabs}">
                <TextBlock Text="Kiriha" FontWeight="SemiBold" FontSize="12.5"
                           Foreground="{DynamicResource TextPrimary}" />
                <Border Width="1" Height="16" Background="{DynamicResource Divider}" />
                <TextBlock Text="{Binding SelectedTab.Title}" MaxWidth="360" FontSize="12.5"
                           Foreground="{DynamicResource TextSecondary}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <ListBox x:Name="TabsListBox" Grid.Column="1" Classes="tabs" Margin="2,0,0,0"
                     Height="42" ClipToBounds="True"
                     AutomationProperties.Name="横タブ"
                     IsVisible="{Binding UseHorizontalTabs}"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                     ItemsSource="{Binding Tabs}"
                     SelectedItem="{Binding SelectedTab}"
                     DragDrop.AllowDrop="True"
                     PointerMoved="Tabs_PointerMoved"
                     PointerReleased="Tabs_PointerReleased">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="1" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:TabViewModel">
                        <StackPanel Orientation="Horizontal" Height="35" Background="Transparent"
                                    ToolTip.Tip="{Binding PathText}">
                            <StackPanel.ContextMenu>
                                <ContextMenu Opened="TabMenu_Opened">
                                    <MenuItem Header="新しいタブを右に開く" Click="TabNewRight_Click" />
                                    <MenuItem Header="タブを複製" Click="TabDuplicate_Click"
                                              IsVisible="{Binding IsNormalTab}" />
                                    <Separator />
                                    <MenuItem Header="タブを固定"
                                              IsVisible="{Binding !IsPinned}"
                                              Command="{Binding TogglePinCommand}" />
                                    <MenuItem Header="タブの固定を解除"
                                              IsVisible="{Binding IsPinned}"
                                              Command="{Binding TogglePinCommand}" />
                                    <Separator />
                                    <MenuItem Header="タブを閉じる"
                                              Command="{Binding CloseSelfCommand}" />
                                    <MenuItem Header="右側のタブを閉じる" Click="TabCloseRight_Click" />
                                    <MenuItem Header="他のタブを閉じる" Click="TabCloseOthers_Click" />
                                    <MenuItem Header="タブの詳細操作" Tag="tabActions" />
                                    <Separator />
                                    <MenuItem Header="閉じたタブを開く" Click="TabReopen_Click"
                                              InputGesture="Ctrl+Shift+T" />
                                    <MenuItem Header="最近閉じたタブ" Tag="recent" />
                                    <Separator />
                                    <MenuItem Header="パスのコピー" Click="TabCopyPath_Click" />
                                    <MenuItem Header="エクスプローラーで開く"
                                              Command="{Binding OpenInExplorerCommand}" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <Border Classes="tabicon">
                                <Grid>
                                    <TextBlock Text="📁" FontSize="12"
                                               IsVisible="{Binding IsNormalTab}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="⚙" FontSize="12"
                                               IsVisible="{Binding IsSettingsTab}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       IsVisible="{Binding !IsPinned}"
                                       Width="128" Margin="8,0,4,0" FontSize="12.5"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Button Classes="tabclose" Content="&#xE8BB;"
                                    IsVisible="{Binding !IsPinned}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    Command="{Binding CloseSelfCommand}" />
                            <!-- 固定タブはタイトル/閉じるボタンが無いので、アイコン枠の左マージン(6)と
                                 対称になる幅の右スペーサーを置いてアイコンをタブ中央に揃える。 -->
                            <Border Width="6" IsVisible="{Binding IsPinned}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button x:Name="HorizontalNewTabButton" Grid.Column="2" Classes="nav" Width="28" Height="28"
                    Margin="6,7,0,0" Content="&#xE710;" FontSize="12"
                    AutomationProperties.Name="新しいタブ"
                    IsVisible="{Binding UseHorizontalTabs}"
                    Command="{Binding NewTabCommand}"
                    ToolTip.Tip="新しいタブ" />

            <!-- キャプションボタン（WindowDecorations=BorderOnly のためシステム側は描画されない） -->
            <StackPanel Grid.Column="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Classes="caption" Content="&#xE921;" Click="Minimize_Click" />
                <Button Classes="caption" Content="&#xE922;" Click="MaximizeRestore_Click" />
                <Button Classes="caption close" Content="&#xE8BB;" Click="Close_Click" />
            </StackPanel>
        </Grid>

        <!-- ===== 垂直タブバー ===== -->
        <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,4"
              Width="{Binding VerticalTabWidth}"
              IsVisible="{Binding UseVerticalTabs}">
            <Border Grid.Column="0" Background="{DynamicResource ContentBg}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0" Height="46" Margin="12,5,8,3"
                          ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                        <TextBlock Text="タブ" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                        <Button x:Name="VerticalNewTabButton" Grid.Column="1" Classes="verticaltabaction"
                                Command="{Binding NewTabCommand}"
                                AutomationProperties.Name="新しいタブ"
                                ToolTip.Tip="新しいタブ (Ctrl+T)">
                            <TextBlock Classes="fico" Text="&#xE710;" FontSize="12" />
                        </Button>
                        <Button x:Name="HorizontalTabModeButton" Grid.Column="2" Classes="verticaltabaction" Content="横タブ"
                                FontSize="11.5"
                                AutomationProperties.Name="横タブに切り替える"
                                Command="{Binding ToggleVerticalTabsCommand}"
                                ToolTip.Tip="横タブに戻す" />
                    </Grid>

                    <ListBox x:Name="VerticalTabsListBox" Grid.Row="1" Classes="verticaltabs"
                             AutomationProperties.Name="垂直タブ"
                             ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab}"
                             DragDrop.AllowDrop="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PointerMoved="Tabs_PointerMoved"
                             PointerReleased="Tabs_PointerReleased">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TabViewModel">
                                <Grid Height="36" ColumnDefinitions="38,*,Auto"
                                      AutomationProperties.Name="{Binding Title}"
                                      Background="Transparent" ToolTip.Tip="{Binding PathText}">
                                    <Grid.ContextMenu>
                                        <ContextMenu Opened="TabMenu_Opened">
                                            <MenuItem Header="新しいタブを右に開く" Click="TabNewRight_Click" />
                                            <MenuItem Header="タブを複製" Click="TabDuplicate_Click"
                                                      IsVisible="{Binding IsNormalTab}" />
                                            <Separator />
                                            <MenuItem Header="タブを固定"
                                                      IsVisible="{Binding !IsPinned}"
                                                      Command="{Binding TogglePinCommand}" />
                                            <MenuItem Header="タブの固定を解除"
                                                      IsVisible="{Binding IsPinned}"
                                                      Command="{Binding TogglePinCommand}" />
                                            <Separator />
                                            <MenuItem Header="タブを閉じる"
                                                      Command="{Binding CloseSelfCommand}" />
                                            <MenuItem Header="右側のタブを閉じる" Click="TabCloseRight_Click" />
                                            <MenuItem Header="他のタブを閉じる" Click="TabCloseOthers_Click" />
                                            <MenuItem Header="タブの詳細操作" Tag="tabActions" />
                                            <Separator />
                                            <MenuItem Header="閉じたタブを開く" Click="TabReopen_Click"
                                                      InputGesture="Ctrl+Shift+T" />
                                            <MenuItem Header="最近閉じたタブ" Tag="recent" />
                                            <Separator />
                                            <MenuItem Header="パスのコピー" Click="TabCopyPath_Click" />
                                            <MenuItem Header="エクスプローラーで開く"
                                                      Command="{Binding OpenInExplorerCommand}" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Grid Grid.Column="0">
                                        <TextBlock Text="📁" FontSize="13"
                                                   IsVisible="{Binding IsNormalTab}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Text="⚙" FontSize="13"
                                                   IsVisible="{Binding IsSettingsTab}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               Margin="0,0,8,0" FontSize="12.5"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Classes="fico" Text="&#xE718;"
                                               IsVisible="{Binding IsPinned}" FontSize="11"
                                               Margin="0,0,10,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"
                                               ToolTip.Tip="固定タブ" />
                                    <Button Grid.Column="2" Classes="tabclose" Content="&#xE8BB;"
                                            IsVisible="{Binding !IsPinned}"
                                            AutomationProperties.Name="タブを閉じる"
                                            Margin="0,0,8,0" VerticalAlignment="Center"
                                            Command="{Binding CloseSelfCommand}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:Name="VerticalSettingsButton" Grid.Row="2" Classes="verticaltabaction" Height="38"
                            Margin="12,4,8,10" HorizontalContentAlignment="Left"
                            AutomationProperties.Name="設定を開く"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip.Tip="設定を開く">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="設定" FontSize="12.5" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
            <Thumb x:Name="VerticalTabsResizeThumb" Grid.Column="1" Classes="colsplit" Width="4"
                   AutomationProperties.Name="垂直タブバーの幅を変更"
                   DragDelta="VerticalTabsThumb_DragDelta" />
        </Grid>

        <!-- ===== 選択中タブの中身 ===== -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding SelectedTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:TabViewModel">
                    <Panel Background="{DynamicResource ContentBg}">

                    <!-- 設定タブの中身。Lhamiel / Shisui / RealTimeTranslator の実装を直接調査し、
                         浮遊カード状サイドバー TabControl + HeaderedContentControl 積みの数値を実測値どおりに再現。 -->
                    <Border IsVisible="{Binding IsSettingsTab}" Background="{DynamicResource SettingsPageBg}">
                        <Grid Margin="24">
                        <TabControl Classes="settingsnav">

                            <!-- ===== 表示 ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE890;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="表示" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <Border Classes="settingshero">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Classes="settingsheroicon">
                                                    <TextBlock Classes="fico" Text="&#xE890;" FontSize="21"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Classes="settingsh1" Text="表示" />
                                                    <TextBlock Classes="settingsherosubtitle" Text="ファイル一覧の見え方とKirihaの外観を調整します" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <HeaderedContentControl Classes="settingscard" Header="エクスプローラー表示">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="隠しファイルを表示する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptShowHidden}" />
                                                <CheckBox Content="ファイル名拡張子を表示する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptShowExtensions}" />
                                                <CheckBox Content="項目チェックボックスを表示する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptShowCheckBoxes}" />
                                                <CheckBox Content="お気に入りバーを表示する (Ctrl+Shift+B)"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowBookmarksBar}" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="タブバー">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="タブをウィンドウ左側へ縦に並べる"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UseVerticalTabs}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="タブ名を広く確認でき、タブ数が増えても縦スクロールで移動できます。左端の境界をドラッグすると幅を変更できます。" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="アイコン">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="Material Icon Theme のアイコンを使う（拡張子ごとに色分け表示）"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptUseMaterialIcons}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="material-icon-theme (MIT License, © Material Extensions) のアイコンを使用しています。" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="テーマ">
                                            <StackPanel Spacing="12">
                                                <!-- 表示は日本語、内部値（settings.json / ApplyTheme の switch）は英語のまま。
                                                     SelectedValueBinding=Tag で ComboBoxItem.Tag を選択値として扱う。 -->
                                                <ComboBox Classes="settingsfield"
                                                          SelectedValue="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptTheme}"
                                                          SelectedValueBinding="{Binding Tag, x:DataType=ComboBoxItem}"
                                                          MinWidth="200" HorizontalAlignment="Left">
                                                    <ComboBoxItem Tag="System">システム</ComboBoxItem>
                                                    <ComboBoxItem Tag="Light">ライト</ComboBoxItem>
                                                    <ComboBoxItem Tag="Dark">ダーク</ComboBoxItem>
                                                    <ComboBoxItem Tag="OneDark">One Dark</ComboBoxItem>
                                                </ComboBox>
                                                <CheckBox Content="ウィンドウにアクリル効果（半透明ぼかし）を使う"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptUseAcrylicBackground}" />
                                            </StackPanel>
                                        </HeaderedContentControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===== 起動 ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE7E8;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="起動" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <Border Classes="settingshero">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Classes="settingsheroicon">
                                                    <TextBlock Classes="fico" Text="&#xE7E8;" FontSize="21"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Classes="settingsh1" Text="起動" />
                                                    <TextBlock Classes="settingsherosubtitle" Text="起動方法、Windows統合、タスクトレイを管理します" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <HeaderedContentControl Classes="settingscard" Header="起動時の動作">
                                            <StackPanel Spacing="8">
                                                <TextBlock Classes="settingscaption" Margin="0"
                                                           Text="新しいタブで開くフォルダー（空欄でユーザーフォルダー）" />
                                                <TextBox Classes="settingsfield"
                                                         Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptStartupPath}"
                                                         MinWidth="400" HorizontalAlignment="Left" />
                                                <CheckBox Content="終了時に開いていたタブを次回復元する" Margin="0,8,0,0"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptRestoreAllTabs}" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="ウィンドウ">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="ウィンドウのサイズと位置を保存する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptRememberWindowBounds}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="OFF にすると、次回は既定のサイズ・位置で起動します。" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="Windows 統合">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="Windows のスタートアップに登録する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptRunAtStartup}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="サインイン時に Kiriha を自動で起動します。" />
                                                <CheckBox Content="エクスプローラーの右クリックメニューに「Kiriha で開く」を追加する" Margin="0,8,0,0"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptExplorerContextMenu}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="フォルダーやフォルダー内の背景を右クリックしたときに、そのフォルダーを Kiriha で開けます。" />
                                                <CheckBox Content="フォルダーとドライブを開く既定のアプリを Kiriha にする" Margin="0,8,0,0"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptDefaultFolderApp}" />
                                                <TextBlock Classes="settingscaption" TextWrapping="Wrap"
                                                           Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptDefaultFolderAppStatus}" />
                                            </StackPanel>
                                        </HeaderedContentControl>

                                        <HeaderedContentControl Classes="settingscard" Header="タスクトレイ">
                                            <StackPanel Classes="settingsfields">
                                                <CheckBox Content="最小化時にタスクトレイに格納する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptMinimizeToTray}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="最小化するとタスクバーから消え、タスクトレイのアイコンから復元できます。" />
                                                <CheckBox Content="起動時にタスクトレイに格納する" Margin="0,8,0,0"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptStartMinimizedToTray}" />
                                                <TextBlock Classes="settingscaption"
                                                           Text="起動直後はウィンドウを表示せず、タスクトレイに格納した状態で開始します。" />
                                            </StackPanel>
                                        </HeaderedContentControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===== 更新 ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE895;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="更新" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <Border Classes="settingshero">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Classes="settingsheroicon">
                                                    <TextBlock Classes="fico" Text="&#xE895;" FontSize="21"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Classes="settingsh1" Text="更新" />
                                                    <TextBlock Classes="settingsherosubtitle" Text="Kirihaを最新の状態に保ちます" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <HeaderedContentControl Classes="settingscard" Header="自動更新">
                                            <StackPanel Spacing="10">
                                                <CheckBox Content="起動時に更新を確認する"
                                                          IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OptCheckUpdatesOnStartup}" />
                                                <Button Classes="cmd" Content="今すぐ更新を確認" Click="CheckUpdate_Click"
                                                        HorizontalAlignment="Left"
                                                        BorderBrush="{DynamicResource Divider}" BorderThickness="1" />
                                            </StackPanel>
                                        </HeaderedContentControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===== メンテナンス ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE90F;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="メンテナンス" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <Border Classes="settingshero">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Classes="settingsheroicon">
                                                    <TextBlock Classes="fico" Text="&#xE90F;" FontSize="21"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Classes="settingsh1" Text="メンテナンス" />
                                                    <TextBlock Classes="settingsherosubtitle" Text="キャッシュ、ログ、設定データを管理します" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <HeaderedContentControl Classes="settingscard" Header="データとキャッシュ">
                                            <StackPanel Spacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Classes="cmd" Content="クイックアクセスを再読み込み"
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ReloadSidebarCommand}"
                                                            BorderBrush="{DynamicResource Divider}" BorderThickness="1" />
                                                    <Button Classes="cmd" Content="ログフォルダーを開く"
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenLogFolderCommand}"
                                                            BorderBrush="{DynamicResource Divider}" BorderThickness="1" />
                                                </StackPanel>
                                                <Button Classes="cmd" Content="設定をリセット"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ResetSettingsCommand}"
                                                        HorizontalAlignment="Left"
                                                        BorderBrush="{DynamicResource Divider}" BorderThickness="1" />
                                            </StackPanel>
                                        </HeaderedContentControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===== ショートカット ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE765;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="ショートカット" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <Border Classes="settingshero">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Classes="settingsheroicon">
                                                    <TextBlock Classes="fico" Text="&#xE765;" FontSize="21"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Classes="settingsh1" Text="ショートカット" />
                                                    <TextBlock Classes="settingsherosubtitle" Text="キーボードで素早く操作するための一覧です" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Grid ColumnDefinitions="*,14,*" RowDefinitions="Auto,Auto">
                                            <HeaderedContentControl Grid.Row="0" Grid.Column="0" Classes="settingscard" Header="タブ">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondary}" LineHeight="24"
                                                           Text="Ctrl+T　新しいタブ&#x0a;Ctrl+W　タブを閉じる&#x0a;Ctrl+Shift+T　閉じたタブを開く&#x0a;Ctrl+Tab　タブを切り替える&#x0a;Ctrl+1..9　指定タブを選択" />
                                            </HeaderedContentControl>
                                            <HeaderedContentControl Grid.Row="0" Grid.Column="2" Classes="settingscard" Header="移動と表示">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondary}" LineHeight="24"
                                                           Text="Ctrl+L / F4　アドレス入力&#x0a;Ctrl+F / F3　検索&#x0a;Alt+← / →　戻る・進む&#x0a;Alt+↑　1つ上へ&#x0a;F5　更新 / F11　全画面" />
                                            </HeaderedContentControl>
                                            <HeaderedContentControl Grid.Row="1" Grid.ColumnSpan="3" Classes="settingscard" Header="ファイル操作">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondary}" LineHeight="24"
                                                           Text="Ctrl+X / C / V　切り取り・コピー・貼り付け　　Delete / Shift+Delete　削除・完全削除&#x0a;F2　名前の変更　　Alt+Enter　プロパティ　　Ctrl+Shift+N　新しいフォルダー　　Alt+P　プレビュー" />
                                            </HeaderedContentControl>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===== バージョン情報 ===== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="fico" Text="&#xE946;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="バージョン情報" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer>
                                    <StackPanel MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,12,0">
                                        <StackPanel Margin="4,0,0,22" Orientation="Horizontal">
                                            <Border Width="76" Height="76" Margin="0,0,18,0"
                                                    Background="{DynamicResource SettingsHeroBg}"
                                                    BorderBrush="{DynamicResource SettingsCardBorder}" BorderThickness="1"
                                                    CornerRadius="18" BoxShadow="0 8 20 0 #22000000">
                                                <Image Width="64" Height="64" Source="avares://Kiriha/icon/app_icon.png"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Kiriha" FontSize="30" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimary}" />
                                                <TextBlock Text="Chromeの操作感とExplorerの機能を融合したファイルマネージャー"
                                                           FontSize="13" Foreground="{DynamicResource TextSecondary}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Classes="settingscard">
                                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="バージョン"
                                                           Margin="0,0,22,0" VerticalAlignment="Center"
                                                           FontSize="13" Foreground="{DynamicResource TextSecondary}" />
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).VersionText}"
                                                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimary}" />
                                                <Button Grid.RowSpan="2" Grid.Column="2" Classes="cmd"
                                                        Content="アップデートを確認" Click="CheckUpdate_Click" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="実行環境"
                                                           Margin="0,10,22,0" FontSize="13"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                                                           Text=".NET 10 / Avalonia UI / Native AOT"
                                                           FontSize="13" Foreground="{DynamicResource TextPrimary}" />
                                            </Grid>
                                        </Border>

                                        <HeaderedContentControl Classes="settingscard" Header="Kiriha について">
                                            <TextBlock FontSize="13" LineHeight="22" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Text="Windows Explorerのファイル操作と、Chromeのタブ・アドレスバー・お気に入り操作を一つの画面にまとめています。設定は現在のユーザーに保存されます。" />
                                        </HeaderedContentControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                        </Grid>
                    </Border>

                    <Grid RowDefinitions="48,Auto,40,*,28" Background="{DynamicResource ContentBg}"
                          IsVisible="{Binding IsNormalTab}">

                        <!-- ナビゲーション + アドレスバー（パンくず） + 検索 -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto"
                              Background="{DynamicResource TabActiveBg}">
                            <Button Grid.Column="0" Classes="nav" Content="&#xE72B;" Margin="8,0,0,0"
                                    Command="{Binding GoBackCommand}" ToolTip.Tip="戻る (右クリックで履歴)"
                                    PointerReleased="NavBack_PointerReleased"
                                    VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="nav" Content="&#xE72A;" Margin="2,0,0,0"
                                    Command="{Binding GoForwardCommand}" ToolTip.Tip="進む (右クリックで履歴)"
                                    PointerReleased="NavForward_PointerReleased"
                                    VerticalAlignment="Center" />
                            <Button Grid.Column="2" Classes="nav" Content="&#xE72C;" Margin="2,0,0,0"
                                    Command="{Binding RefreshCommand}" ToolTip.Tip="更新"
                                    VerticalAlignment="Center" />
                            <Button Grid.Column="3" Classes="nav" Content="&#xE74A;" Margin="2,0,0,0"
                                    Command="{Binding GoUpCommand}" ToolTip.Tip="1 つ上へ (右クリックで祖先一覧)"
                                    PointerReleased="NavUp_PointerReleased"
                                    VerticalAlignment="Center" />
                            <Button Grid.Column="4" Classes="nav" Content="&#xE80F;" Margin="2,0,0,0"
                                    Click="Home_Click" ToolTip.Tip="ホーム (Alt+Home / 右クリックでよく使うフォルダー)"
                                    PointerReleased="Home_PointerReleased"
                                    VerticalAlignment="Center" />

                            <Border Grid.Column="5" Background="{DynamicResource OmniboxBg}" CornerRadius="17"
                                    Height="34" Margin="8,0,12,0" VerticalAlignment="Center"
                                    PointerPressed="BreadcrumbBar_PointerPressed"
                                    PointerReleased="BreadcrumbBar_PointerReleased">

                                <Grid ColumnDefinitions="*,40">
                                    <!-- パンくずリスト（Windows 11 相当） -->
                                    <ScrollViewer Grid.Column="0" IsVisible="{Binding !IsEditingPath}"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  VerticalAlignment="Center"
                                                  Margin="8,0">
                                        <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="m:BreadcrumbSegment">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Classes="crumb" Content="{Binding Name}"
                                                                Command="{Binding $parent[ItemsControl].((vm:TabViewModel)DataContext).NavigateToPathCommand}"
                                                                CommandParameter="{Binding Path}"
                                                                PointerReleased="Crumb_PointerReleased" />
                                                        <!-- シェブロンクリックでサブフォルダーのドロップダウン（エクスプローラーと同じ） -->
                                                        <Button Classes="crumb" Padding="2,3" Click="CrumbChevron_Click">
                                                            <TextBlock Classes="fico" Text="&#xE76C;" FontSize="9"
                                                                       Foreground="{DynamicResource TextSecondary}"
                                                                       VerticalAlignment="Center" />
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- 長いパスでも直接入力へ切り替えられる固定クリック領域 -->
                                    <Border Grid.Column="1" Background="Transparent"
                                            IsVisible="{Binding !IsEditingPath}"
                                            ToolTip.Tip="クリックしてパスを編集" />

                                    <!-- 直接入力モード -->
                                    <TextBox Grid.ColumnSpan="2" IsVisible="{Binding IsEditingPath}"
                                             Text="{Binding PathText}"
                                             KeyDown="PathBox_KeyDown"
                                             LostFocus="PathBox_LostFocus"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="13.5"
                                             Foreground="{DynamicResource TextPrimary}"
                                             VerticalContentAlignment="Center"
                                             Margin="10,0">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <!-- 検索ボックス幅の変更 -->
                            <Thumb Grid.Column="6" Classes="searchsplit"
                                   DragDelta="SearchBoxThumb_DragDelta" />

                            <!-- 検索ボックス（絞り込み / Enter でサブフォルダー含む検索） -->
                            <Border Grid.Column="7"
                                    Width="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SearchBoxWidth}"
                                    Height="34"
                                    Background="{DynamicResource OmniboxBg}" CornerRadius="17"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Classes="fico" Text="&#xE721;" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Classes="searchbox"
                                             Text="{Binding SearchText}"
                                             PlaceholderText="{Binding SearchPlaceholder}"
                                             KeyDown="SearchBox_KeyDown"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="12.5"
                                             Foreground="{DynamicResource TextPrimary}"
                                             VerticalContentAlignment="Center"
                                             Margin="4,0,10,0">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                    <Button Grid.Column="2" Classes="tabclose" Content="&#xE8BB;"
                                            Margin="0,0,8,0" VerticalAlignment="Center"
                                            ToolTip.Tip="検索をクリア"
                                            IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Click="SearchClear_Click" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- お気に入りバー（Ctrl+Shift+B で表示切替 / DnD 登録 / Chrome 互換右クリック） -->
                        <Border Grid.Row="1" Classes="bookmarkbar" Height="32"
                                Background="{DynamicResource TabActiveBg}"
                                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowBookmarksBar}"
                                DragDrop.AllowDrop="True"
                                PointerReleased="BookmarkBar_PointerReleased">
                            <Panel>
                            <TextBlock Text="ここにフォルダーをドラッグするとお気に入りに追加されます"
                                       FontSize="11.5" Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="14,0"
                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).HasNoBookmarks}" />
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center" Margin="8,0">
                                <ItemsControl ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BookmarkItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="m:BookmarkNode">
                                            <Button Classes="bookmark"
                                                    ToolTip.Tip="{Binding Path}"
                                                    Click="Bookmark_Click"
                                                    PointerReleased="BookmarkItem_PointerReleased">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="📁" FontSize="11" IsVisible="{Binding IsFolder}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="⭐" FontSize="11" IsVisible="{Binding !IsFolder}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                               MaxWidth="160" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            </Panel>
                        </Border>

                        <!-- コマンドバー（エクスプローラー同等） -->
                        <Border Grid.Row="2" Background="{DynamicResource ContentBg}"
                                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="10,0" Spacing="2">
                                <Button Classes="cmd" VerticalAlignment="Center" Click="NewButton_Click"
                                        IsEnabled="{Binding CanCreateNew}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE710;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="新規作成" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Border Width="1" Height="20" Background="{DynamicResource Divider}"
                                        VerticalAlignment="Center" Margin="4,0" />

                                <Button Classes="cmd cmdicon" Content="&#xE8C6;" ToolTip.Tip="切り取り (Ctrl+X)"
                                        VerticalAlignment="Center" Command="{Binding CutCommand}" />
                                <Button Classes="cmd cmdicon" Content="&#xE8C8;" ToolTip.Tip="コピー (Ctrl+C)"
                                        VerticalAlignment="Center" Command="{Binding CopyCommand}" />
                                <Button Classes="cmd cmdicon" Content="&#xE77F;" ToolTip.Tip="貼り付け (Ctrl+V)"
                                        VerticalAlignment="Center" Command="{Binding PasteCommand}" />
                                <Button Classes="cmd cmdicon" Content="&#xE8AC;" ToolTip.Tip="名前の変更 (F2)"
                                        VerticalAlignment="Center" Command="{Binding RenameCommand}" />
                                <Button Classes="cmd cmdicon" Content="&#xE72D;" ToolTip.Tip="共有"
                                        VerticalAlignment="Center" Command="{Binding ShareCommand}" />
                                <Button Classes="cmd cmdicon" Content="&#xE74D;" ToolTip.Tip="削除 (Delete)"
                                        VerticalAlignment="Center" Command="{Binding DeleteCommand}" />

                                <Border Width="1" Height="20" Background="{DynamicResource Divider}"
                                        VerticalAlignment="Center" Margin="4,0" />

                                <Button Classes="cmd" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE8CB;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="並べ替え" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                            <MenuItem Header="名前" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortByName}"
                                                      Command="{Binding SetSortKeyCommand}" CommandParameter="Name" />
                                            <MenuItem Header="更新日時" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortByModified}"
                                                      Command="{Binding SetSortKeyCommand}" CommandParameter="Modified" />
                                            <MenuItem Header="作成日時" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortByCreated}"
                                                      Command="{Binding SetSortKeyCommand}" CommandParameter="Created" />
                                            <MenuItem Header="種類" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortByType}"
                                                      Command="{Binding SetSortKeyCommand}" CommandParameter="Type" />
                                            <MenuItem Header="サイズ" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortBySize}"
                                                      Command="{Binding SetSortKeyCommand}" CommandParameter="Size" />
                                            <Separator />
                                            <MenuItem Header="昇順" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortAscending}"
                                                      Command="{Binding SetSortAscendingCommand}" CommandParameter="True" />
                                            <MenuItem Header="降順" ToggleType="Radio"
                                                      IsChecked="{Binding IsSortDescending}"
                                                      Command="{Binding SetSortAscendingCommand}" CommandParameter="False" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>

                                <Button Classes="cmd" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE890;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="表示" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                            <MenuItem Header="特大アイコン" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewExtraLarge}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="ExtraLargeIcons" />
                                            <MenuItem Header="大アイコン" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewLarge}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="LargeIcons" />
                                            <MenuItem Header="中アイコン" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewMedium}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="MediumIcons" />
                                            <MenuItem Header="小アイコン" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewSmall}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="SmallIcons" />
                                            <MenuItem Header="一覧" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewList}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="List" />
                                            <MenuItem Header="詳細" ToggleType="Radio"
                                                      IsChecked="{Binding IsViewDetails}"
                                                      Command="{Binding SetViewModeCommand}" CommandParameter="Details" />
                                            <Separator />
                                            <MenuItem Header="コンパクトビュー" ToggleType="CheckBox"
                                                      IsChecked="{Binding IsCompactView}"
                                                      Command="{Binding ToggleCompactViewCommand}" />
                                            <Separator />
                                            <MenuItem Header="ナビゲーションウィンドウ" ToggleType="CheckBox"
                                                      IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowSidebar}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSidebarCommand}" />
                                            <MenuItem Header="プレビューウィンドウ" ToggleType="CheckBox"
                                                      InputGesture="Alt+P"
                                                      IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowPreviewPane}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).TogglePreviewPaneCommand}" />
                                            <MenuItem Header="ステータスバー" ToggleType="CheckBox"
                                                      IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowStatusBar}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleStatusBarCommand}" />
                                            <Separator />
                                            <MenuItem Header="隠しファイル" ToggleType="CheckBox"
                                                      IsChecked="{Binding ShowHidden}"
                                                      Command="{Binding ToggleShowHiddenCommand}" />
                                            <MenuItem Header="ファイル名拡張子" ToggleType="CheckBox"
                                                      IsChecked="{Binding ShowExtensions}"
                                                      Command="{Binding ToggleShowExtensionsCommand}" />
                                            <MenuItem Header="項目チェックボックス" ToggleType="CheckBox"
                                                      IsChecked="{Binding ShowCheckBoxes}"
                                                      Command="{Binding ToggleShowCheckBoxesCommand}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>

                                <Button Classes="cmd" VerticalAlignment="Center" Click="LocationsButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE838;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="場所" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="cmd" VerticalAlignment="Center" Click="FileTypeFilterButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE71C;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="種類" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="cmd" VerticalAlignment="Center" Click="AdvancedToolsButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Classes="fico" Text="&#xE90F;" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="ツール" VerticalAlignment="Center" />
                                        <TextBlock Classes="fico" Text="&#xE70D;" FontSize="9" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="cmd cmdicon" Content="&#xE712;" ToolTip.Tip="もっと見る"
                                        VerticalAlignment="Center">
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                            <MenuItem Header="すべて選択" Click="SelectAll_Click" InputGesture="Ctrl+A" />
                                            <MenuItem Header="選択解除" Click="SelectNone_Click" />
                                            <MenuItem Header="選択の切り替え" Click="SelectInvert_Click" />
                                            <MenuItem Header="フォルダーだけ選択" Click="SelectFolders_Click" />
                                            <MenuItem Header="ファイルだけ選択" Click="SelectFiles_Click" />
                                            <Separator />
                                            <MenuItem Header="コマンドパレット" Click="CommandPalette_Click" InputGesture="Ctrl+Shift+P" />
                                            <Separator />
                                            <MenuItem Header="ターミナルで開く" Command="{Binding OpenTerminalCommand}" />
                                            <MenuItem Header="エクスプローラーで開く" Command="{Binding OpenInExplorerCommand}" />
                                            <MenuItem Header="クイックアクセスにピン留め" Click="PinToQuickAccess_Click" />
                                            <MenuItem Header="お気に入りに追加" Click="AddBookmark_Click" InputGesture="Ctrl+D" />
                                            <Separator />
                                            <MenuItem Header="パスのコピー" Click="CopyPath_Click" InputGesture="Ctrl+Shift+C" />
                                            <MenuItem Header="プロパティ" Command="{Binding ShowPropertiesCommand}" />
                                            <MenuItem Header="お気に入りバー" ToggleType="CheckBox"
                                                      IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowBookmarksBar}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleBookmarksBarCommand}" />
                                            <Separator />
                                            <MenuItem Header="新しいウィンドウ" Click="NewWindow_Click" InputGesture="Ctrl+N" />
                                            <MenuItem Header="オプション"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenSettingsCommand}" />
                                            <MenuItem Header="更新の確認" Click="CheckUpdate_Click" />
                                            <MenuItem Header="Kiriha について"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenSettingsCommand}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 左ペイン + ファイル一覧 + プレビュー -->
                        <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                            <!-- 左ペイン: Windows のクイックアクセス + PC -->
                            <!-- 右の仕切り線は隣の Thumb (colsplit) が描くため Border 側には引かない -->
                            <Border Grid.Column="0" Background="{DynamicResource SidebarBg}"
                                    Width="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarWidth}"
                                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowSidebar}">
                                <ListBox Classes="sidebar"
                                         DragDrop.AllowDrop="True"
                                         ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarItems}"
                                         Loaded="Sidebar_Loaded"
                                         SelectionChanged="Sidebar_SelectionChanged"
                                         PointerReleased="Sidebar_PointerReleased">
                                    <ListBox.DataTemplates>
                                        <DataTemplate DataType="m:SidebarHeader">
                                            <TextBlock Text="{Binding Title}" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiary}" FontWeight="SemiBold"
                                                       Margin="4,8,0,2" />
                                        </DataTemplate>
                                        <DataTemplate DataType="m:SidebarLink">
                                            <StackPanel Orientation="Horizontal" Spacing="10"
                                                        Background="Transparent"
                                                        ToolTip.Tip="{Binding Tooltip}">
                                                <TextBlock Text="{Binding Icon}" FontSize="13"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.DataTemplates>
                                </ListBox>
                            </Border>

                            <!-- 左ペイン幅の変更 -->
                            <Thumb Grid.Column="1" Classes="colsplit" Width="4"
                                   IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowSidebar}"
                                   DragDelta="SidebarThumb_DragDelta" />

                            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                                <!-- 詳細表示のカラムヘッダー（クリックでソート / Thumb で幅変更） -->
                                <ItemsControl Grid.Row="0" ItemsSource="{Binding DetailColumns}"
                                              Margin="12,2,0,2" Background="Transparent"
                                              PointerReleased="ColumnHeader_PointerReleased"
                                              IsVisible="{Binding IsDetailsView}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DetailColumnViewModel">
                                            <Border Classes="detailcolumn" Width="{Binding Width}"
                                                    Classes.dragging="{Binding IsDragging}"
                                                    Classes.droptarget="{Binding IsDropTarget}"
                                                    IsVisible="{Binding IsVisible}">
                                                <Grid ColumnDefinitions="*,6">
                                                    <Button Grid.Column="0" Classes="colhead"
                                                            Command="{Binding Owner.SortByColumnCommand}"
                                                            CommandParameter="{Binding Key}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Title}" FontSize="12" />
                                                            <TextBlock Classes="fico" Text="{Binding SortGlyph}" FontSize="9"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Thumb Grid.Column="1" Classes="colsplit" DragDelta="ColumnThumb_DragDelta" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Row="0" Height="1" Background="{DynamicResource Divider}" VerticalAlignment="Bottom"
                                        IsVisible="{Binding IsDetailsView}" />

                                <Panel Grid.Row="1">
                                    <!-- 詳細表示 -->
                                    <ListBox Classes="files details"
                                             Margin="0,0,30,0"
                                             IsVisible="{Binding IsDetailsView}"
                                             ItemsSource="{Binding Entries}"
                                             SelectedItem="{Binding SelectedEntry}"
                                             SelectionMode="Multiple"
                                             Background="Transparent"
                                             DragDrop.AllowDrop="True"
                                             DoubleTapped="FileList_DoubleTapped"
                                             SelectionChanged="FileList_SelectionChanged"
                                             PointerReleased="FileList_PointerReleased"
                                             KeyDown="FileList_KeyDown">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:FileSystemEntry">
                                                <ItemsControl Margin="8,0,0,0"
                                                            ItemsSource="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).DetailColumns}"
                                                            Background="Transparent"
                                                            Height="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).RowHeight}"
                                                            Opacity="{Binding RowOpacity}"
                                                            ToolTip.Tip="{Binding RowTooltip}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:DetailColumnViewModel">
                                                            <Panel Width="{Binding Width}" IsVisible="{Binding IsVisible}">
                                                                <Grid IsVisible="{Binding IsName}" ColumnDefinitions="Auto,Auto,*">
                                                                    <CheckBox Grid.Column="0" MinWidth="0" Padding="0" Margin="0,0,6,0"
                                                                              IsVisible="{Binding Owner.ShowCheckBoxes}"
                                                                              IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" />
                                                                    <Image Grid.Column="1" Source="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).MaterialIcon}"
                                                                           IsVisible="{Binding Owner.ShowMaterialIcons}"
                                                                           Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).Icon}" FontSize="14"
                                                                               IsVisible="{Binding Owner.UseEmojiIcons}"
                                                                               Margin="0,0,10,0" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="2" Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).DisplayName}" FontSize="13"
                                                                               Foreground="{DynamicResource TextPrimary}"
                                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                </Grid>
                                                                <Grid IsVisible="{Binding IsModified}" ClipToBounds="True">
                                                                    <TextBlock Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).ModifiedText}" FontSize="12.5" Padding="6,0,0,0"
                                                                               IsVisible="{Binding !$parent[ItemsControl].((m:FileSystemEntry)DataContext).IsDrive}"
                                                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                                                    <ProgressBar IsVisible="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).IsDrive}"
                                                                                 Minimum="0" Maximum="100"
                                                                                 Value="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).DriveUsedPercent}"
                                                                                 MinWidth="0" HorizontalAlignment="Stretch"
                                                                                 Height="10" Margin="6,0,12,0" VerticalAlignment="Center" />
                                                                </Grid>
                                                                <TextBlock IsVisible="{Binding IsCreated}"
                                                                           Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).CreatedText}" FontSize="12.5" Padding="6,0,0,0"
                                                                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                                                <TextBlock IsVisible="{Binding IsType}"
                                                                           Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).TypeText}" FontSize="12.5" Padding="6,0,0,0"
                                                                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock IsVisible="{Binding IsSize}"
                                                                           Text="{Binding $parent[ItemsControl].((m:FileSystemEntry)DataContext).SizeText}" FontSize="12.5" Padding="6,0,6,0"
                                                                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                                                                           TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                            </Panel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Width="30" HorizontalAlignment="Right" Background="Transparent"
                                            IsVisible="{Binding IsDetailsView}"
                                            PointerPressed="FileListClearArea_PointerPressed"
                                            ToolTip.Tip="クリックして選択を解除" />

                                    <!-- 一覧 / 小アイコン表示 -->
                                    <ListBox Classes="files list"
                                             IsVisible="{Binding IsListView}"
                                             ItemsSource="{Binding Entries}"
                                             SelectedItem="{Binding SelectedEntry}"
                                             SelectionMode="Multiple"
                                             Background="Transparent"
                                             Padding="12,8,0,0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             DragDrop.AllowDrop="True"
                                             DoubleTapped="FileList_DoubleTapped"
                                             SelectionChanged="FileList_SelectionChanged"
                                             PointerReleased="FileList_PointerReleased"
                                             KeyDown="FileList_KeyDown">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <c:VirtualizingWrapPanel Orientation="Vertical"
                                                                         ItemWidth="220"
                                                                         MaximumItemWidth="380"
                                                                         ItemHeight="{Binding ListRowHeight}"
                                                                         CacheRows="1" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:FileSystemEntry">
                                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,0"
                                                            Background="Transparent"
                                                            Height="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).ListRowHeight}"
                                                            Opacity="{Binding RowOpacity}">
                                                    <CheckBox MinWidth="0" Padding="0" Margin="0,0,-4,0"
                                                              IsVisible="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).ShowCheckBoxes}"
                                                              IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}" />
                                                    <Image Source="{Binding MaterialIcon}"
                                                           IsVisible="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).ShowMaterialIcons}"
                                                           Width="16" Height="16" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Icon}" FontSize="14"
                                                               IsVisible="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).UseEmojiIcons}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- アイコン表示（特大 / 大 / 中） -->
                                    <ListBox Classes="icons"
                                             IsVisible="{Binding IsIconsView}"
                                             ItemsSource="{Binding Entries}"
                                             SelectedItem="{Binding SelectedEntry}"
                                             SelectionMode="Multiple"
                                             Background="Transparent"
                                             DragDrop.AllowDrop="True"
                                             DoubleTapped="FileList_DoubleTapped"
                                             SelectionChanged="FileList_SelectionChanged"
                                             PointerReleased="FileList_PointerReleased"
                                             KeyDown="FileList_KeyDown">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <c:VirtualizingWrapPanel ItemWidth="{Binding IconCellWidth}"
                                                                         ItemHeight="{Binding IconCellHeight}" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:FileSystemEntry">
                                                <StackPanel Width="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).IconItemWidth}"
                                                            EffectiveViewportChanged="IconItem_EffectiveViewportChanged"
                                                            Background="Transparent"
                                                            Opacity="{Binding RowOpacity}"
                                                            ToolTip.Tip="{Binding RowTooltip}">
                                                    <!-- 優先順位: 実サムネイル > Material アイコン > 絵文字 -->
                                                    <Image Source="{Binding Thumbnail}"
                                                           IsVisible="{Binding HasThumbnail}"
                                                           Height="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).IconFontSize}"
                                                           Stretch="Uniform" />
                                                    <Panel IsVisible="{Binding HasNoThumbnail}">
                                                        <Image Source="{Binding MaterialIcon}"
                                                               IsVisible="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).ShowMaterialIcons}"
                                                               Width="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).IconFontSize}"
                                                               Height="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).IconFontSize}"
                                                               Stretch="Uniform" />
                                                        <TextBlock Text="{Binding Icon}"
                                                                   IsVisible="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).UseEmojiIcons}"
                                                                   FontSize="{Binding $parent[ListBox].((vm:TabViewModel)DataContext).IconFontSize}"
                                                                   HorizontalAlignment="Center" />
                                                    </Panel>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"
                                                               MaxLines="2" TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <!-- 空フォルダー表示 -->
                                    <TextBlock Text="このフォルダーは空です。"
                                               IsVisible="{Binding HasNoEntries}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="13"
                                               HorizontalAlignment="Center" Margin="0,60,0,0" />
                                </Panel>
                            </Grid>

                            <!-- プレビューペイン幅の変更 -->
                            <Thumb Grid.Column="3" Classes="colsplit" Width="4"
                                   IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowPreviewPane}"
                                   DragDelta="PreviewThumb_DragDelta" />

                            <!-- プレビューペイン (Alt+P) -->
                            <!-- 左の仕切り線は隣の Thumb (colsplit) が描くため Border 側には引かない -->
                            <Border Grid.Column="4"
                                    Width="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PreviewWidth}"
                                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowPreviewPane}"
                                    Background="{DynamicResource SidebarBg}">
                                <Grid RowDefinitions="*,Auto" Margin="10">
                                    <Panel Grid.Row="0">
                                        <Image Source="{Binding PreviewBitmap}"
                                               Stretch="Uniform" StretchDirection="DownOnly"
                                               VerticalAlignment="Top" />
                                        <ScrollViewer IsVisible="{Binding PreviewText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                      Background="{DynamicResource ContentBg}">
                                            <TextBlock Text="{Binding PreviewText}" FontSize="11"
                                                       FontFamily="Cascadia Mono,Consolas,MS Gothic"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="NoWrap" Margin="8" />
                                        </ScrollViewer>
                                    </Panel>
                                    <TextBlock Grid.Row="1" Text="{Binding PreviewInfo}" FontSize="11.5"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap" Margin="0,8,0,0" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ステータスバー（エクスプローラー同等: 項目数 | 選択情報 | 空き領域） -->
                        <Border Grid.Row="4" Background="{DynamicResource StatusBg}"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowStatusBar}"
                                BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,Auto" Margin="14,0">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding StatusText}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center" />
                                    <Border Width="1" Height="14" Background="{DynamicResource StatusDivider}" VerticalAlignment="Center"
                                            IsVisible="{Binding SelectionText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    <TextBlock Text="{Binding SelectionText}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding FreeSpaceText}" FontSize="11.5"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                    <!-- Finder 風のアイコンサイズスライダー（アイコン表示時のみ） -->
                                    <Slider Width="110" Minimum="24" Maximum="160"
                                            Value="{Binding IconSize}"
                                            IsVisible="{Binding IsIconsView}"
                                            VerticalAlignment="Center" Margin="0,-8"
                                            ToolTip.Tip="アイコンのサイズ" />
                                    <!-- エクスプローラー右下と同じ表示切替ボタン -->
                                    <Button Classes="cmd cmdicon" Width="26" Height="22" FontSize="12"
                                            Content="&#xE8FD;" ToolTip.Tip="詳細表示"
                                            Command="{Binding SetViewModeCommand}" CommandParameter="Details" />
                                    <Button Classes="cmd cmdicon" Width="26" Height="22" FontSize="12"
                                            Content="&#xE8A9;" ToolTip.Tip="大アイコン表示"
                                            Command="{Binding SetViewModeCommand}" CommandParameter="LargeIcons" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                    </Panel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
    </Panel>
</Window>
