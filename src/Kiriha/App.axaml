<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Kiriha.Services"
             x:Class="Kiriha.App">
    <!-- RequestedThemeVariant 未指定 = Windows のダーク / ライト設定に自動追従 -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Chrome ライト配色 -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TabStripBg" Color="#DEE1E6" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="#EAECEF" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="#F1F3F5" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="ContentBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="#F1F3F4" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#F8F9FA" />
                    <SolidColorBrush x:Key="StatusBg" Color="#F8F9FA" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#202124" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#5F6368" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#80868B" />
                    <SolidColorBrush x:Key="Divider" Color="#E8EAED" />
                    <SolidColorBrush x:Key="HoverBg" Color="#E8EAED" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="#E1E3E6" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="#CDD0D5" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="#D0D3D9" />
                    <SolidColorBrush x:Key="StatusDivider" Color="#D0D3D9" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="#F3F6FA" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="#D9E0E8" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="#E4EDF9" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="#EAF2FC" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="#D7E7FA" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="#E8EDF3" />
                    <Color x:Key="AcrylicTintColor">#DEE1E6</Color>
                </ResourceDictionary>
                <!-- Chrome ダーク配色 -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TabStripBg" Color="#202124" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="#2A2B2F" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="#34363B" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="#45474D" />
                    <SolidColorBrush x:Key="ContentBg" Color="#35363A" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="#202124" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#2B2C2F" />
                    <SolidColorBrush x:Key="StatusBg" Color="#2B2C2F" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#9AA0A6" />
                    <SolidColorBrush x:Key="Divider" Color="#4A4B4F" />
                    <SolidColorBrush x:Key="HoverBg" Color="#4A4B4F" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="#45474B" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="#5F6368" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="#5F6368" />
                    <SolidColorBrush x:Key="StatusDivider" Color="#5F6368" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="#25282E" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="#2C3037" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="#30343B" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="#464C56" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="#484E58" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="#293746" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="#344C65" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="#50555F" />
                    <Color x:Key="AcrylicTintColor">#202124</Color>
                </ResourceDictionary>
                <!-- One Dark 配色（Atom One Dark 由来の青みがかったダーク）。
                     ThemeDictionaries のキーは ThemeVariant 型で、既定コンバーターは Light/Dark/Default の
                     組み込みリテラルしか文字列から変換できないため、カスタムバリアントは x:Static で
                     ThemeService.OneDark の静的インスタンスを直接参照する必要がある。 -->
                <ResourceDictionary x:Key="{x:Static services:ThemeService.OneDark}">
                    <SolidColorBrush x:Key="TabStripBg" Color="#21252B" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="#272B32" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="#2C313A" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="#282C34" />
                    <SolidColorBrush x:Key="ContentBg" Color="#282C34" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="#1B1D23" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#21252B" />
                    <SolidColorBrush x:Key="StatusBg" Color="#21252B" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#ABB2BF" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#828997" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#5C6370" />
                    <SolidColorBrush x:Key="Divider" Color="#3E4451" />
                    <SolidColorBrush x:Key="HoverBg" Color="#2C313A" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="#333842" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="#3E4451" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="#3E4451" />
                    <SolidColorBrush x:Key="StatusDivider" Color="#3E4451" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="#21252B" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="#282C34" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="#2C313A" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="#3E4451" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="#2C4356" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="#1F2937" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="#2C4356" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="#3E4451" />
                    <Color x:Key="AcrylicTintColor">#21252B</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

</Application>
