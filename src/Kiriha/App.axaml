<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Kiriha.Services"
             x:Class="Kiriha.App">
    <!-- RequestedThemeVariant 未指定 = Windows のダーク / ライト設定に自動追従 -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Chrome ライト配色 -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TabStripBg" Color="#DEE1E6" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="#EAECEF" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="#F1F3F5" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="ContentBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="#F1F3F4" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#F8F9FA" />
                    <SolidColorBrush x:Key="StatusBg" Color="#F8F9FA" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#202124" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#5F6368" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#80868B" />
                    <SolidColorBrush x:Key="Divider" Color="#E8EAED" />
                    <SolidColorBrush x:Key="HoverBg" Color="#E8EAED" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="#E1E3E6" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="#CDD0D5" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="#D0D3D9" />
                    <SolidColorBrush x:Key="StatusDivider" Color="#D0D3D9" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="#F3F6FA" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="#D9E0E8" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="#E4EDF9" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="#EAF2FC" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="#D7E7FA" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="#E8EDF3" />
                    <Color x:Key="AcrylicTintColor">#DEE1E6</Color>
                </ResourceDictionary>
                <!-- Chrome ダーク配色 -->
                <ResourceDictionary x:Key="Dark">
                    <!-- 黒系サーフェスは土台・面・操作状態の3段階だけに限定する。 -->
                    <Color x:Key="NeutralBase">#202124</Color>
                    <Color x:Key="NeutralSurface">#2B2C2F</Color>
                    <Color x:Key="NeutralInteractive">#3C4043</Color>
                    <SolidColorBrush x:Key="TabStripBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="ContentBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="SidebarBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="StatusBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#E8EAED" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#9AA0A6" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#9AA0A6" />
                    <SolidColorBrush x:Key="Divider" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="StatusDivider" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="{StaticResource NeutralSurface}" />
                    <Color x:Key="AcrylicTintColor">#202124</Color>
                </ResourceDictionary>
                <!-- One Dark 配色（Atom One Dark 由来の青みがかったダーク）。
                     ThemeDictionaries のキーは ThemeVariant 型で、既定コンバーターは Light/Dark/Default の
                     組み込みリテラルしか文字列から変換できないため、カスタムバリアントは x:Static で
                     ThemeService.OneDark の静的インスタンスを直接参照する必要がある。 -->
                <ResourceDictionary x:Key="{x:Static services:ThemeService.OneDark}">
                    <!-- One Dark も同じ3役へ正規化し、青みだけをテーマの個性として残す。 -->
                    <Color x:Key="NeutralBase">#21252B</Color>
                    <Color x:Key="NeutralSurface">#282C34</Color>
                    <Color x:Key="NeutralInteractive">#3E4451</Color>
                    <SolidColorBrush x:Key="TabStripBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="TabIdleBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="TabHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="TabActiveBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="ContentBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="OmniboxBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="SidebarBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="StatusBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#ABB2BF" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#828997" />
                    <SolidColorBrush x:Key="TextTertiary" Color="#5C6370" />
                    <SolidColorBrush x:Key="Divider" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="CrumbHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="CaptionHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="TabCloseHoverBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="StatusDivider" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsPageBg" Color="{StaticResource NeutralBase}" />
                    <SolidColorBrush x:Key="SettingsNavBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsCardBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsCardBorder" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsNavSelected" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsHeroBg" Color="{StaticResource NeutralSurface}" />
                    <SolidColorBrush x:Key="SettingsIconBg" Color="{StaticResource NeutralInteractive}" />
                    <SolidColorBrush x:Key="SettingsButtonBg" Color="{StaticResource NeutralSurface}" />
                    <Color x:Key="AcrylicTintColor">#21252B</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

</Application>
